{
  "name": "marine-mammal-assessment",
  "private": true,
  "type": "module",
  "description": "Open-source, offline-first platform for marine mammal field assessments",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:integration": "tsx scripts/run-integration-tests.ts",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^20.17.14",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "tsx": "^4.19.2",
    "vitest": "^3.0.4"
  }
}
