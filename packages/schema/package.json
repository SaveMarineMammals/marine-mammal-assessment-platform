{
  "name": "@mmap/schema",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "MMAP assessment JSON Schemas, types, and validators",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manatee_v1": {
      "types": "./dist/manatee_v1/index.d.ts",
      "import": "./dist/manatee_v1/index.js"
    },
    "./manatee_v1/assessment.schema.json": "./schemas/manatee_v1/assessment.schema.json",
    "./manatee_v1/measurement.schema.json": "./schemas/manatee_v1/measurement.schema.json",
    "./manatee_v1/definitions.schema.json": "./schemas/manatee_v1/definitions.schema.json",
    "./dolphin_v1": {
      "types": "./dist/dolphin_v1/index.d.ts",
      "import": "./dist/dolphin_v1/index.js"
    },
    "./registry.json": "./registry.json",
    "./form-definitions/manatee_v1.json": "./form-definitions/manatee_v1.json",
    "./form-definitions/dolphin_v1.json": "./form-definitions/dolphin_v1.json",
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run --config vitest.config.ts",
    "lint": "eslint src"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
