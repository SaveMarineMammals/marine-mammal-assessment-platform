{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mmap.example/schemas/dolphin_v1/measurement.schema.json",
  "title": "Dolphin Measurement (stub)",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "assessment_id", "measurement_type", "recorded_at", "value", "unit"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "assessment_id": { "type": "string", "format": "uuid" },
        "measurement_type": { "const": "body_condition" },
        "recorded_at": { "type": "string", "format": "date-time" },
        "value": { "type": "integer", "minimum": 1, "maximum": 5 },
        "unit": { "const": "score" },
        "notes": { "type": ["string", "null"] },
        "sequence": { "type": "integer", "minimum": 1 }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "assessment_id", "measurement_type", "recorded_at", "value", "unit"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "assessment_id": { "type": "string", "format": "uuid" },
        "measurement_type": { "const": "respiratory_rate" },
        "recorded_at": { "type": "string", "format": "date-time" },
        "value": { "type": "number", "exclusiveMinimum": 0 },
        "unit": { "const": "breaths/min" },
        "notes": { "type": ["string", "null"] },
        "sequence": { "type": "integer", "minimum": 1 }
      }
    }
  ]
}
