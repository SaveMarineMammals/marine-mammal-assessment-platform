PORT=3001
HOST=0.0.0.0
DATABASE_URL=postgresql://mmap:mmap@localhost:5432/mmap
# Or pass on the command line: pnpm db:migrate -- --database-url postgresql://mmap:mmap@localhost:5432/mmap
API_ADMIN_TOKEN=dev-admin-token
# Comma-separated browser origins allowed to call the API (field PWA dev server by default)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
PUBLIC_PSEUDONYMIZE_NAMES=false
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=mmap
